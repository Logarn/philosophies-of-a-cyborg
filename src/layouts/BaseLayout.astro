---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = 'Philosophies of a Cyborg',
  description = 'Essays from Logarn on AI, agency, software, and the strange business of becoming partially machine.',
  bodyClass = ''
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/" aria-label="Philosophies of a Cyborg home">
          <span class="brand-mark">P</span>
          <span>Philosophies of a Cyborg</span>
        </a>
        <nav class="nav" aria-label="Primary navigation">
          <a href="/essays/">Essays</a>
          <a href="/#socials">Socials</a>
        </nav>
      </header>
      <slot />
      <footer class="footer">
        <strong>Philosophies of a Cyborg.</strong> Light mode only. Search-free. Tiny readership, sharp knives.
      </footer>
    </div>
  </body>
</html>
