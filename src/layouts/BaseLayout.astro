---
import '../styles/global.css';
import { contact } from '../lib/contact';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  canonicalPath?: string;
  image?: string;
  ogType?: string;
  robots?: string;
}

const {
  title = contact.siteName,
  description = `Essays from ${contact.name} on AI, agency, software, and the strange business of becoming partially machine.`,
  bodyClass = '',
  canonicalPath = Astro.url.pathname,
  image = '/logo-mark.png',
  ogType = 'website',
  robots = 'index,follow'
} = Astro.props;

const canonical = new URL(canonicalPath, Astro.site ?? Astro.url).toString();
const absoluteImage = new URL(image, Astro.site ?? Astro.url).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: contact.siteName,
  url: new URL('/', Astro.site ?? Astro.url).toString(),
  publisher: {
    '@type': 'Person',
    name: contact.name
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={contact.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicons/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')}></script>
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/" aria-label={`${contact.siteName} home`}>
          <span class="brand-mark"><img src="/logo-mark.png" alt="" /></span>
          <span>{contact.siteName}</span>
        </a>
        <nav class="nav" aria-label="Primary navigation">
          <a href="/essays/">Essays</a>
          <a href="/#socials">Socials</a>
        </nav>
      </header>
      <slot />
      <footer class="footer">
        <strong>{contact.siteName}.</strong> Light mode only. Search-free. A room for {contact.name}'s rough notes.
      </footer>
    </div>
  </body>
</html>
