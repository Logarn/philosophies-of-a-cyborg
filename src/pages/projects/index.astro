---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contact } from '../../lib/contact';
import { projectCopy } from '../../lib/siteCopy';

const projects = projectCopy;
---

<BaseLayout title={`Project OS | ${contact.siteName}`}>
  <main class="page">
    <section class="section quiet-page">
      <div class="section-head">
        <h2>Project OS</h2>
        <p class="section-note">A parking lot for the things I am building, breaking, or quietly thinking about.</p>
      </div>
      <div class="essay-grid">
        {projects.map((project) => (
          <article class="essay-card">
            <span class="pin">Project</span>
            <h3>{project.title}</h3>
            <p>{project.summary}</p>
            <p>
              Domain: {project.domain}
            </p>
            <p>
              <a href={`/projects/${project.slug}/`}>View details</a>
              {project.repo && (
                <>
                  {' / '}
                  <a href={project.repo}>View repo</a>
                </>
              )}
            </p>
            <span class="read-time">{project.status}</span>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
