---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contact } from '../../lib/contact';
import { getPublishedEssayBySlug, renderMarkdown } from '../../lib/essays';

export const prerender = false;

const slug = Astro.params.slug ?? '';
const essay = await getPublishedEssayBySlug(slug);
if (!essay) return new Response('Essay not found', { status: 404 });

const canonicalPath = `/essays/${slug}/`;
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: essay.data.title,
  description: essay.data.summary,
  datePublished: essay.data.publishedAt.toISOString(),
  dateModified: (essay.data.updatedAt ?? essay.data.publishedAt).toISOString(),
  author: {
    '@type': 'Person',
    name: contact.name
  },
  publisher: {
    '@type': 'Organization',
    name: contact.siteName,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/logo-mark.png', Astro.site ?? Astro.url).toString()
    }
  },
  mainEntityOfPage: new URL(canonicalPath, Astro.site ?? Astro.url).toString()
};
---

<BaseLayout
  title={`${essay.data.title} | ${contact.siteName}`}
  description={essay.data.summary}
  canonicalPath={canonicalPath}
  ogType="article"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleJsonLd).replace(/</g, '\\u003c')}></script>
  <article class="article">
    <span class="pin">{essay.data.pinned ? 'Pinned essay' : essay.data.readingTime}</span>
    <h1>{essay.data.title}</h1>
    <p class="dek">{essay.data.summary}</p>
    <time datetime={essay.data.publishedAt.toISOString()}>
      {essay.data.publishedAt.toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}
    </time>
    <div class="article-body" set:html={renderMarkdown(essay.body)} />
  </article>
</BaseLayout>
