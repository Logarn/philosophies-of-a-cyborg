---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssayCard from '../../components/EssayCard.astro';
import { essaySlug, getPublishedEssays, splitPinned } from '../../lib/essays';
import { contact } from '../../lib/contact';

const essays = await getPublishedEssays();
const { pinned, rest } = splitPinned(essays);
---

<BaseLayout title={`Essays | ${contact.siteName}`}>
  <main class="page">
    <section class="section">
      <div class="section-head">
        <h2>Essays</h2>
        <p class="section-note">Pinned notes first. Everything else sits below as cards because that is enough for now.</p>
      </div>
      <div class="essay-grid">
        {pinned.map((essay) => (
          <EssayCard
            href={'/essays/' + essaySlug(essay) + '/'}
            title={essay.data.title}
            summary={essay.data.summary}
            date={essay.data.publishedAt}
            readingTime={essay.data.readingTime}
            pinned
          />
        ))}
      </div>
    </section>

    <section class="section">
      <div class="essay-grid essay-grid-wide">
        {rest.map((essay) => (
          <EssayCard
            href={'/essays/' + essaySlug(essay) + '/'}
            title={essay.data.title}
            summary={essay.data.summary}
            date={essay.data.publishedAt}
            readingTime={essay.data.readingTime}
          />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
