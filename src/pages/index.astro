---
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/EssayCard.astro';
import { getPublishedEssays, splitPinned } from '../lib/essays';
import { contact, contactHref } from '../lib/contact';
import { socials } from '../lib/socials';

const essays = await getPublishedEssays();
const { pinned, rest } = splitPinned(essays);

const navItems = [
  { label: 'Project OS', href: '/projects/' },
  { label: 'Calculator', modal: 'calculator' },
  { label: 'Essays', href: '/essays/' },
  { label: 'Values', href: '/values/' },
  { label: 'Archive', href: '/archive/' },
  { label: 'Handbook', href: '/handbook/' },
  { label: 'Substack', href: socials.substack, external: true }
];

const leftIcons = [
  { label: 'home', href: '/', icon: 'doc', mark: 'Aa' },
  { label: 'Project OS', href: '/projects/', icon: 'book', mark: 'P' },
  { label: 'Calculator', modal: 'calculator', icon: 'calculator', mark: '$' },
  { label: 'Clock', action: 'open-clock', icon: 'clock', mark: 'EAT' },
  { label: 'Video', href: contactHref.youtube, external: true, icon: 'video', mark: 'PLAY' },
  { label: 'Essays', href: '/essays/', icon: 'book', mark: 'E' },
  { label: 'LinkedIn', href: socials.linkedin, external: true, icon: 'linkedin', mark: 'in' },
  { label: 'Instagram', href: socials.instagram, external: true, icon: 'instagram', mark: '◎' },
  { label: 'Substack', href: socials.substack, external: true, icon: 'substack', mark: 'S' },
  { label: 'Reddit', href: contactHref.reddit, external: true, icon: 'reddit', mark: 'r/' },
  { label: 'talk2', href: contactHref.email, icon: 'mail', mark: '@', ariaLabel: `talk2 ${contact.name}` },
  { label: 'Call me', href: contactHref.phone, icon: 'chat', mark: '☎', ariaLabel: `Call ${contact.name}` },
  { label: 'Switch to agent mode', action: 'agent-mode', icon: 'switch', mark: 'T' }
];

const rightIcons = [
  { label: 'My values', href: '/values/', icon: 'bookshelf', mark: 'V', external: false },
  { label: 'Company handbook', href: '/handbook/', icon: 'openbook', mark: 'H', external: false },
  { label: 'Store', href: '/store/', icon: 'bag', mark: 'S', external: false },
  { label: 'Archive', href: '/archive/', icon: 'trash', mark: 'A', external: false }
];

const conversionZones = [
  { key: 'est', label: 'Eastern', city: 'EST/EDT' },
  { key: 'pst', label: 'Pacific', city: 'PST/PDT' },
  { key: 'cst', label: 'Central', city: 'CST/CDT' },
  { key: 'gmt', label: 'GMT', city: 'London' },
  { key: 'cet', label: 'Central Europe', city: 'CET/CEST' },
  { key: 'sast', label: 'SAST', city: 'Johannesburg' }
];
---

<BaseLayout bodyClass="home-desktop-page">
  <main class="posthog-home">
    <section class="retro-desktop" aria-label={`${contact.siteName} reader desktop`}>
      <header class="posthog-nav" aria-label="Homepage navigation">
        <a class="posthog-logo site-logo" href="/" aria-label={`${contact.siteName} home`}>
          <img src="/logo-mark.png" alt="" />
        </a>
        <nav aria-label="Desktop navigation">
          {navItems.map((item) => (
            item.modal ? (
              <button type="button" data-modal={item.modal}>{item.label}</button>
            ) : (
              <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
                {item.label}
              </a>
            )
          ))}
        </nav>
        <div class="nav-tools" aria-label="Homepage tools">
          <a class="nav-cta" href="/essays/">Read the rough notes</a>
        </div>
      </header>

      <div class="desktop-canvas">
        <div class="icon-rail icon-rail-left" aria-label="Primary desktop shortcuts">
          {leftIcons.map((item) => (
            item.action ? (
              <button class="desktop-object" type="button" data-action={item.action}>
                <span class:list={['desktop-glyph', `icon-${item.icon}`]} aria-hidden="true">
                  <span>{item.mark}</span>
                </span>
                <span class="desktop-label">{item.label}</span>
              </button>
            ) : item.modal ? (
              <button class="desktop-object" type="button" data-modal={item.modal}>
                <span class:list={['desktop-glyph', `icon-${item.icon}`]} aria-hidden="true">
                  <span>{item.mark}</span>
                </span>
                <span class="desktop-label">{item.label}</span>
              </button>
            ) : (
              <a
                class="desktop-object"
                href={item.href}
                aria-label={item.ariaLabel}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noreferrer' : undefined}
              >
                <span class:list={['desktop-glyph', `icon-${item.icon}`]} aria-hidden="true">
                  <span>{item.mark}</span>
                </span>
                <span class="desktop-label">{item.label}</span>
              </a>
            )
          ))}
        </div>

        <section class="garden-scene garden-game" data-letter-game aria-label="Letter prize garden game">
          <div class="garden-plot plot-back" aria-hidden="true">
            <i class="flower-row flowers-blue"></i>
            <i class="flower-row flowers-red"></i>
            <i class="flower-row flowers-yellow"></i>
          </div>
          <div class="garden-plot plot-left" aria-hidden="true">
            <i class="sprouts sprouts-a"></i>
            <i class="sprouts sprouts-b"></i>
          </div>
          <div class="soil-plot plot-center">
            <i></i><i></i><i></i><i></i><i></i><i></i>
          </div>
          <div class="wood-bed">
            <span></span><span></span><span></span><span></span>
          </div>
          <div class="water-plot" aria-hidden="true">
            <i></i><i></i><i></i>
          </div>
          <div class="garden-plot plot-front" aria-hidden="true">
            <i class="sprouts sprouts-c"></i>
          </div>
          <div class="reader-figure">
            <span></span>
          </div>
          <div class="garden-shadow"></div>
          <div class="garden-game-panel">
            <h2>Play Game to win prize</h2>
            <p>Organize these letters to reveal your prize.</p>
            <span class="game-hint">Hint: You C***</span>
            <div class="letter-slots" data-letter-slots aria-label="Prize answer slots"></div>
            <div class="letter-tray" data-letter-tray aria-label="Scrambled letters"></div>
            <div class="letter-actions">
              <button type="button" data-letter-shuffle>Scramble</button>
              <button type="button" data-letter-undo>Undo</button>
              <output data-letter-status>Tap letters in order.</output>
            </div>
          </div>
        </section>

        <div class="icon-rail icon-rail-right" aria-label="Secondary desktop shortcuts">
          {rightIcons.map((item) => (
            <a
              class="desktop-object"
              href={item.href}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noreferrer' : undefined}
            >
              <span class:list={['desktop-glyph', `icon-${item.icon}`]} aria-hidden="true">
                <span>{item.mark}</span>
              </span>
              <span class="desktop-label">{item.label}</span>
            </a>
          ))}
        </div>

        <section class="desktop-widget time-console" data-clock-window aria-label="East African Time clock and converter">
          <div class="widget-bar">
            <span>EAT CLOCK</span>
            <span data-eat-date>--</span>
          </div>
          <strong data-eat-clock>--:--:-- EAT</strong>
          <p class="time-note">Pick a Nairobi date and time. The rows show the actual local clock, including daylight saving.</p>
          <div class="time-converter">
            <div class="time-field">
              <label for="eat-date-input">EAT date</label>
              <input id="eat-date-input" type="date" data-eat-date-input />
            </div>
            <div class="time-field">
              <label for="eat-time-input">EAT time</label>
              <input id="eat-time-input" type="time" data-eat-input />
            </div>
            <div class="time-input-row">
              <button type="button" data-eat-now>Now</button>
            </div>
          </div>
          <div class="zone-grid" aria-label="Converted times">
            {conversionZones.map((zone) => (
              <div class="zone-row">
                <span>
                  <strong>{zone.label}</strong>
                  <small>{zone.city}</small>
                </span>
                <output data-zone={zone.key}>--:--</output>
              </div>
            ))}
          </div>
        </section>

        <div class="desktop-modal-layer" data-modal-layer hidden>
          <section class="desktop-modal calc-modal" data-modal-panel="calculator" role="dialog" aria-modal="true" aria-labelledby="calculator-title">
            <div class="window-bar">
              <span id="calculator-title" class="window-title">CALCULATOR.EXE</span>
              <button type="button" data-modal-close aria-label="Close calculator"><span aria-hidden="true"></span></button>
            </div>
            <div class="calc-body">
              <div class="calc-screen" aria-live="polite">
                <strong data-calc-display>0</strong>
                <span data-calc-lesson>Tap constants and operators. This one rewards curiosity.</span>
              </div>
              <div class="calc-grid">
                {['7', '8', '9', '/', 'π', '4', '5', '6', '*', 'φ', '1', '2', '3', '-', 'c', '0', '.', '=', '+', 'E'].map((key) => (
                  <button type="button" class:list={['calc-key', { 'is-easter': ['π', 'φ', 'c', 'E'].includes(key), 'is-equals': key === '=' }]} data-key={key}>
                    {key}
                  </button>
                ))}
                <button type="button" class="calc-key calc-wide" data-key="F=ma">F=ma</button>
                <button type="button" class="calc-key calc-wide" data-key="∫">Integral</button>
                <button type="button" class="calc-key calc-wide" data-key="clear">Clear</button>
              </div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="home-reading-strip" aria-label="Pinned essays">
      <div class="section-head">
        <h2>Pinned</h2>
        <p class="section-note">A few notes I would probably point someone to first.</p>
      </div>
      <div class="essay-grid">
        {pinned.map((essay) => (
          <EssayCard
            href={'/essays/' + essay.slug + '/'}
            title={essay.data.title}
            summary={essay.data.summary}
            date={essay.data.publishedAt}
            readingTime={essay.data.readingTime}
            pinned
          />
        ))}
      </div>
    </section>

    <section class="home-reading-strip" aria-label="All essays">
      <div class="section-head">
        <h2>All essays</h2>
        <p class="section-note">A long card wall for the public archive. No list view, no admin dashboard.</p>
      </div>
      <div class="essay-grid essay-grid-wide">
        {rest.map((essay) => (
          <EssayCard
            href={'/essays/' + essay.slug + '/'}
            title={essay.data.title}
            summary={essay.data.summary}
            date={essay.data.publishedAt}
            readingTime={essay.data.readingTime}
          />
        ))}
      </div>
    </section>
  </main>

  <section class="agent-readable" aria-label="Agent-readable homepage summary">
    <h1>{contact.siteName}</h1>
    <p>Rough essays from {contact.name} on AI, agency, software, ambition, and becoming partially machine.</p>

    <h2>Canonical reader page</h2>
    <p><a href="/">Human website homepage</a></p>
    <p><a href="/">Human mode</a></p>

    <h2>Primary routes</h2>
    <ul>
      <li><a href="/essays/">Essays index</a></li>
      <li><a href="/projects/">Project OS</a></li>
      <li><a href="/values/">My values</a></li>
      <li><a href="/store/">Store coming soon</a></li>
      <li><a href="/archive/">Archive</a></li>
      <li><a href={socials.linkedin}>LinkedIn profile</a></li>
      <li><a href={socials.instagram}>Instagram profile</a></li>
      <li><a href={socials.substack}>Substack publication</a></li>
      <li><a href={contactHref.reddit}>Reddit profile</a></li>
      <li><a href={contactHref.youtube}>YouTube search</a></li>
      <li><a href={contactHref.email}>Email {contact.name}</a></li>
      <li><a href={contactHref.phone}>Call {contact.name}</a></li>
      <li>Calculator: open the human homepage and choose Calculator.</li>
    </ul>

    <h2>Pinned essays</h2>
    <ul>
      {pinned.map((essay) => (
        <li>
          <a href={'/essays/' + essay.slug + '/'}>{essay.data.title}</a>
          <p>{essay.data.summary}</p>
        </li>
      ))}
    </ul>

    <h2>All essays</h2>
    <ul>
      {rest.map((essay) => (
        <li>
          <a href={'/essays/' + essay.slug + '/'}>{essay.data.title}</a>
          <p>{essay.data.summary}</p>
        </li>
      ))}
    </ul>
  </section>

  <script>
    import '../scripts/home-game';
  </script>
</BaseLayout>
