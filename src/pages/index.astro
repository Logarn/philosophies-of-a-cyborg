---
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/EssayCard.astro';
import { getPublishedEssays, splitPinned } from '../lib/essays';
import { socials } from '../lib/socials';
import { homepageCopy } from '../lib/siteCopy';

const essays = await getPublishedEssays();
const { pinned, rest } = splitPinned(essays);
const latest = rest.slice(0, 6);
const desktopEssays = [...pinned, ...latest].slice(0, 4);
const selectedEssay = desktopEssays[0];
const totalReadingMinutes = essays.reduce((total, essay) => {
  const minutes = Number.parseInt(essay.data.readingTime, 10);
  return total + (Number.isFinite(minutes) ? minutes : 0);
}, 0);
---

<BaseLayout>
  <main class="page home-page">
    <div class="visual-home">
      <section class="desktop-hero" aria-label="Reader desktop">
        <div class="hero-window window">
          <div class="window-bar">
            <span class="window-title">PHILOSOPHIES.TXT</span>
            <span class="window-controls" aria-hidden="true"><i></i><i></i><i></i></span>
          </div>
          <div class="hero-window-body">
            <p class="hero-kicker">{homepageCopy.eyebrow}</p>
            <h1>{homepageCopy.headline}</h1>
            <p class="hero-copy">
              {homepageCopy.intro}
            </p>
            <div class="hero-actions">
              <a class="button primary" href="/essays/">{homepageCopy.cta}</a>
              <button class="button" type="button" data-action="agent-mode">Agent-readable mode</button>
            </div>
          </div>
        </div>

        <aside class="desktop-stage" aria-label="Retro desktop preview">
          <div id="socials" class="desktop-icons" aria-label="Social links">
            <a class="desktop-icon social-icon" href={socials.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn profile">
              <span class="icon-tile icon-linkedin" aria-hidden="true">
                <svg viewBox="0 0 32 32" role="img">
                  <rect x="5" y="5" width="22" height="22" rx="2"></rect>
                  <path d="M11 14v10M11 10.2v.1M16 24v-9.7M16 18.1c.8-2.4 5-2.7 5 1.4V24"></path>
                </svg>
              </span>
              <span>LinkedIn</span>
            </a>
            <a class="desktop-icon social-icon" href={socials.instagram} target="_blank" rel="noreferrer" aria-label="Instagram profile">
              <span class="icon-tile icon-instagram" aria-hidden="true">
                <svg viewBox="0 0 32 32" role="img">
                  <rect x="7" y="7" width="18" height="18" rx="5"></rect>
                  <circle cx="16" cy="16" r="4"></circle>
                  <circle cx="21.5" cy="10.5" r="1.2"></circle>
                </svg>
              </span>
              <span>Instagram</span>
            </a>
            <a class="desktop-icon social-icon" href={socials.substack} target="_blank" rel="noreferrer" aria-label="Substack publication">
              <span class="icon-tile icon-substack" aria-hidden="true">
                <svg viewBox="0 0 32 32" role="img">
                  <path d="M8 7h16M8 12h16M8 17h16v9l-8-4-8 4z"></path>
                </svg>
              </span>
              <span>Substack</span>
            </a>
          </div>

          <div class="reader-window window">
            <div class="window-bar">
              <span class="window-title">READER.EXE</span>
              <span class="window-controls" aria-hidden="true"><i></i><i></i><i></i></span>
            </div>
            <div class="scorebar">
              <span>Essays<strong>{essays.length}</strong></span>
              <span>Pinned<strong>{pinned.length}</strong></span>
              <span>Minutes<strong>{totalReadingMinutes}</strong></span>
            </div>
            {selectedEssay && (
              <div class="thought-board" aria-live="polite">
                <p class="preview-label">Selected file</p>
                <h2 data-preview-title>{selectedEssay.data.title}</h2>
                <p data-preview-summary>{selectedEssay.data.summary}</p>
                <dl>
                  <div>
                    <dt>Saved</dt>
                    <dd data-preview-date>
                      {selectedEssay.data.publishedAt.toLocaleDateString('en', { month: 'short', day: 'numeric' })}
                    </dd>
                  </div>
                  <div>
                    <dt>Length</dt>
                    <dd data-preview-reading>{selectedEssay.data.readingTime}</dd>
                  </div>
                </dl>
              </div>
            )}
            <div class="play-controls">
              <button type="button" data-action="spotlight">Spotlight</button>
              <button type="button" data-action="next">Next file</button>
              <button type="button" data-action="open">Open</button>
            </div>
          </div>

          <div class="document-stack" aria-label="Featured essay shortcuts">
            {desktopEssays.map((essay, index) => (
              <button
                class:list={['desktop-file', { 'is-selected': index === 0 }]}
                type="button"
                data-file
                data-href={'/essays/' + essay.slug + '/'}
                data-title={essay.data.title}
                data-summary={essay.data.summary}
                data-date={essay.data.publishedAt.toLocaleDateString('en', { month: 'short', day: 'numeric' })}
                data-reading-time={essay.data.readingTime}
                data-pinned={essay.data.pinned ? 'true' : 'false'}
              >
                <span class="file-icon" aria-hidden="true"></span>
                <span>{essay.data.title}</span>
              </button>
            ))}
          </div>
        </aside>
      </section>

      <section class="section pinned-section">
        <div class="section-head">
          <h2>Pinned</h2>
          <p class="section-note">The favorites sit up top. No search bar. No fake discovery stack. Just the best hooks first.</p>
        </div>
        <div class="essay-grid">
          {pinned.map((essay) => (
            <EssayCard
              href={'/essays/' + essay.slug + '/'}
              title={essay.data.title}
              summary={essay.data.summary}
              date={essay.data.publishedAt}
              readingTime={essay.data.readingTime}
              pinned
            />
          ))}
        </div>
      </section>

      <section class="section">
        <div class="section-head">
          <h2>Latest</h2>
          <p class="section-note">The rest can scroll. A long page is fine. No control tower required.</p>
        </div>
        <div class="essay-list">
          {latest.map((essay) => (
            <a class="essay-row" href={'/essays/' + essay.slug + '/'}>
              <time datetime={essay.data.publishedAt.toISOString()}>
                {essay.data.publishedAt.toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
              <span>
                <h3>{essay.data.title}</h3>
                <p>{essay.data.summary}</p>
              </span>
              <span class="read-time">{essay.data.readingTime}</span>
            </a>
          ))}
        </div>
      </section>
    </div>

    <section class="agent-readable" aria-label="Agent-readable homepage summary">
      <h1>Philosophies of a Cyborg</h1>
      <p>Essays from Logarn on AI, agency, software, ambition, and becoming partially machine.</p>

      <h2>Canonical reader page</h2>
      <p><a href="/">Human website homepage</a></p>

      <h2>Primary routes</h2>
      <ul>
        <li><a href="/essays/">Essays index</a></li>
        <li><a href={socials.linkedin}>LinkedIn profile</a></li>
        <li><a href={socials.instagram}>Instagram profile</a></li>
        <li><a href={socials.substack}>Substack publication</a></li>
      </ul>

      <h2>Pinned essays</h2>
      <ul>
        {pinned.map((essay) => (
          <li>
            <a href={'/essays/' + essay.slug + '/'}>{essay.data.title}</a>
            <p>{essay.data.summary}</p>
          </li>
        ))}
      </ul>

      <h2>Latest essays</h2>
      <ul>
        {latest.map((essay) => (
          <li>
            <a href={'/essays/' + essay.slug + '/'}>{essay.data.title}</a>
            <p>{essay.data.summary}</p>
          </li>
        ))}
      </ul>
    </section>

    <script>
      import '../scripts/home-game';
    </script>
  </main>
</BaseLayout>
