---
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/EssayCard.astro';
import { getPublishedEssays, splitPinned } from '../lib/essays';
import { socials } from '../lib/socials';

const essays = await getPublishedEssays();
const { pinned, rest } = splitPinned(essays);
const latest = rest.slice(0, 6);
---

<BaseLayout>
  <main class="page">
    <section class="hero">
      <div>
        <p class="eyebrow">Public brain, low tolerance</p>
        <h1>Logarn writes.</h1>
        <p class="hero-copy">
          Essays on AI, agency, software, ambition, and the awkward moment where the machine starts finishing your sentences better than your friends.
        </p>
        <div id="socials" class="socials" aria-label="Social links">
          <a class="button primary" href={socials.linkedin}>LinkedIn</a>
          <a class="button" href={socials.instagram}>Instagram</a>
          <a class="button" href="/essays/">Read essays</a>
        </div>
      </div>

      <aside class="playbox" aria-label="Interactive homepage toy">
        <div class="scorebar">
          <span>Readers<strong>10</strong></span>
          <span>Signal<strong>98</strong></span>
          <span>Noise<strong>0</strong></span>
        </div>
        <div class="thought-board">
          <span class="token" data-tone="red">AI</span>
          <span class="token" data-tone="blue">EGO</span>
          <span class="token" data-tone="green">CODE</span>
          <span class="token" data-tone="yellow">GOD?</span>
        </div>
        <div class="play-controls">
          <button type="button" data-action="spark">Spark</button>
          <button type="button" data-action="shuffle">Shuffle</button>
          <button type="button" data-action="read">Read</button>
        </div>
      </aside>
      <script>
        import '../scripts/home-game';
      </script>
    </section>

    <section class="section">
      <div class="section-head">
        <h2>Pinned</h2>
        <p class="section-note">The favorites sit up top. No search bar. No fake discovery stack. Just the best hooks first.</p>
      </div>
      <div class="essay-grid">
        {pinned.map((essay) => (
          <EssayCard
            href={'/essays/' + essay.slug + '/'}
            title={essay.data.title}
            summary={essay.data.summary}
            date={essay.data.publishedAt}
            readingTime={essay.data.readingTime}
            pinned
          />
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2>Latest</h2>
        <p class="section-note">The rest can scroll. A long page is fine. George Hotz survived without a control tower.</p>
      </div>
      <div class="essay-list">
        {latest.map((essay) => (
          <a class="essay-row" href={'/essays/' + essay.slug + '/'}>
            <time datetime={essay.data.publishedAt.toISOString()}>
              {essay.data.publishedAt.toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
            <span>
              <h3>{essay.data.title}</h3>
              <p>{essay.data.summary}</p>
            </span>
            <span class="read-time">{essay.data.readingTime}</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
