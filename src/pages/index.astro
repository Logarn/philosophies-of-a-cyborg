---
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/EssayCard.astro';
import { essaySlug, getPublishedEssays, splitPinned } from '../lib/essays';
import { contact, contactHref } from '../lib/contact';
import { socials } from '../lib/socials';
import { homepageCopy } from '../lib/siteCopy';

const essays = await getPublishedEssays();
const { pinned, rest } = splitPinned(essays);
const movieListUrl = 'https://rogue-toothbrush-725.notion.site/Movie-List-eec453938bc74522a29891050746f375';
const isAgentMode = Astro.url.searchParams.get('mode') === 'agent';

const navItems = [
  { label: 'Project OS', href: '/projects/' },
  { label: 'Quantum Teacher', href: '/#quantum-teacher', modal: 'quantum-teacher' },
  { label: 'Essays', href: '/essays/' },
  { label: 'Values', href: '/values/' },
  { label: 'Archive', href: '/archive/' },
  { label: 'Handbook', href: '/handbook/' },
  { label: 'Substack', href: socials.substack, external: true }
];

const leftIcons = [
  { label: 'home', action: 'home', icon: 'home', mark: '' },
  { label: 'Project OS', href: '/projects/', icon: 'compass', mark: 'OS' },
  { label: 'Quantum Teacher', href: '/#quantum-teacher', modal: 'quantum-teacher', icon: 'quantum', mark: 'Q' },
  { label: 'Movie List', href: movieListUrl, external: true, icon: 'movie', mark: 'MOV' },
  { label: 'Video', href: contactHref.youtube, external: true, icon: 'video', mark: 'PLAY' },
  { label: 'Essays', href: '/essays/', icon: 'typewriter', mark: 'E' },
  { label: 'LinkedIn', href: socials.linkedin, external: true, icon: 'linkedin', mark: 'in' },
  { label: 'Instagram', href: socials.instagram, external: true, icon: 'instagram', mark: '◎' },
  { label: 'Substack', href: socials.substack, external: true, icon: 'substack', mark: 'S' },
  { label: 'Reddit', href: contactHref.reddit, external: true, icon: 'reddit', mark: 'r/' },
  { label: 'talk2me', href: contactHref.email, icon: 'mail', mark: '@', ariaLabel: `talk2me ${contact.name}` },
  { label: 'Switch to agent mode', href: '/?mode=agent', icon: 'switch', mark: 'T' },
  { label: 'My values', href: '/values/', icon: 'bookshelf', mark: 'V', external: false },
  { label: 'Company handbook', href: '/handbook/', icon: 'openbook', mark: 'H', external: false },
  { label: 'Store', href: '/store/', icon: 'bag', mark: 'S', external: false },
  { label: 'Archive', href: '/archive/', icon: 'trash', mark: 'A', external: false }
];

const fallbackGameLetters = [
  { letter: '!', color: '#8fb247' },
  { letter: 'C', color: '#5f9e5f' },
  { letter: 'y', color: '#bb9b42' },
  { letter: 't', color: '#58a6a9' },
  { letter: 'o', color: '#9aa64b' },
  { letter: 'u', color: '#7fb85a' },
  { letter: 'n', color: '#d78b3b' },
  { letter: 'u', color: '#e3c44e' }
];
---

<BaseLayout bodyClass={`home-desktop-page${isAgentMode ? ' agent-mode' : ''}`}>
  {!isAgentMode && (
  <main class="posthog-home">
    <section id="desktop-home" class="retro-desktop" aria-label={`${contact.siteName} reader desktop`}>
      <header class="posthog-nav" aria-label="Homepage navigation">
        <a class="posthog-logo site-logo" href="/#desktop-home" aria-label={`${contact.siteName} home`}>
          <img src="/logo-mark.png" alt="" />
        </a>
        <nav aria-label="Desktop navigation">
          {navItems.map((item) => (
            item.modal ? (
              <a href={item.href} data-modal={item.modal}>{item.label}</a>
            ) : (
              <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
                {item.label}
              </a>
            )
          ))}
        </nav>
        <div class="nav-tools" aria-label="Homepage tools">
          <a class="nav-cta" href="/essays/">{homepageCopy.nav.ctaLabel}</a>
        </div>
      </header>

      <div class="desktop-canvas">
        <div id="socials" class="icon-rail icon-rail-left" aria-label="Primary desktop shortcuts and socials">
          {leftIcons.map((item) => (
            item.action ? (
              <button class="desktop-object" type="button" data-action={item.action}>
                <span class:list={['desktop-glyph', `icon-${item.icon}`]} aria-hidden="true">
                  <span>{item.mark}</span>
                </span>
                <span class="desktop-label">{item.label}</span>
              </button>
            ) : item.modal ? (
              <a class="desktop-object" href={item.href} data-modal={item.modal}>
                <span class:list={['desktop-glyph', `icon-${item.icon}`]} aria-hidden="true">
                  <span>{item.mark}</span>
                </span>
                <span class="desktop-label">{item.label}</span>
              </a>
            ) : (
              <a
                class="desktop-object"
                href={item.href}
                aria-label={item.ariaLabel}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noreferrer' : undefined}
              >
                <span class:list={['desktop-glyph', `icon-${item.icon}`]} aria-hidden="true">
                  <span>{item.mark}</span>
                </span>
                <span class="desktop-label">{item.label}</span>
              </a>
            )
          ))}
        </div>

        <section class="garden-scene garden-game" data-letter-game aria-label="Draggable letter garden game">
          <div class="garden-motes" aria-hidden="true">
            <i></i><i></i><i></i><i></i><i></i>
          </div>
          <div class="garden-path" aria-hidden="true"></div>
          <div class="reader-figure">
            <span></span>
          </div>
          <div class="garden-shadow"></div>
          <div class="garden-sign">
            <h2>{homepageCopy.garden.title}</h2>
            <p>{homepageCopy.garden.intro}</p>
            <span class="game-hint">{homepageCopy.garden.hint}</span>
            <div class="letter-actions">
              <button type="button" data-letter-shuffle>{homepageCopy.garden.buttonLabel}</button>
            </div>
          </div>
          <div class="letter-slots" data-letter-slots aria-label="Prize answer garden beds">
            {fallbackGameLetters.map((_, index) => (
              <button
                type="button"
                class:list={['letter-slot', index === 3 && 'word-break']}
                data-slot-index={String(index)}
                aria-label={`Answer bed ${index + 1}`}
              ></button>
            ))}
          </div>
          <div class="letter-tray" data-letter-tray aria-label="Draggable scrambled garden letters">
            {fallbackGameLetters.map((tile) => (
              <button
                type="button"
                class="letter-tile"
                draggable="true"
                style={`--piece-color: ${tile.color}`}
                aria-label={`Move garden piece ${tile.letter}`}
              >
                <span class="letter-face">{tile.letter}</span>
              </button>
            ))}
          </div>
          <output class="garden-status" data-letter-status>Tap or drag the garden pieces into the answer beds.</output>
          <dialog class="prize-dialog" data-prize-dialog aria-labelledby="prize-dialog-title">
            <div class="prize-window">
              <div class="einstein-dance" role="img" aria-label="Cartoon Albert Einstein dancing">
                <span class="einstein-hair hair-left"></span>
                <span class="einstein-hair hair-right"></span>
                <span class="einstein-head">
                  <i></i>
                </span>
                <span class="einstein-body"></span>
                <span class="einstein-arm arm-left"></span>
                <span class="einstein-arm arm-right"></span>
                <span class="einstein-leg leg-left"></span>
                <span class="einstein-leg leg-right"></span>
              </div>
              <h2 id="prize-dialog-title">CONGRATULATIONS!</h2>
              <p>You found it: YOU CUNT!</p>
              <button type="button" data-prize-close>Claim prize</button>
            </div>
          </dialog>
          <dialog class="prize-dialog lose-dialog" data-lose-dialog aria-labelledby="lose-dialog-title" hidden>
            <div class="prize-window lose-window">
              <div class="fail-burst" aria-hidden="true">
                <span></span><span></span><span></span><span></span>
              </div>
              <h2 id="lose-dialog-title">TRY AGAIN</h2>
              <p>Wrong garden. The grass has declined your application.</p>
              <button type="button" data-lose-close>Try again</button>
            </div>
          </dialog>
        </section>

        <div class="desktop-modal-layer" data-modal-layer hidden>
          <section id="quantum-teacher" class="desktop-modal quantum-modal" data-modal-panel="quantum-teacher" role="dialog" aria-modal="true" aria-labelledby="quantum-title">
            <div class="window-bar">
              <span id="quantum-title" class="window-title">QUANTUM_TEACHER.EXE</span>
              <button type="button" data-modal-close aria-label="Close Quantum Teacher"><span aria-hidden="true"></span></button>
            </div>
            <div class="quantum-body">
              <div class="quantum-progress" aria-label="Quantum Teacher story progress">
                <span data-quantum-progress></span>
              </div>
              <article class="quantum-card" aria-live="polite" aria-atomic="true">
                <p class="quantum-kicker" data-quantum-kicker>Story 01 / 08</p>
                <h2 data-quantum-title>Atomic fire</h2>
                <p data-quantum-fact>
                  In 1945, Oppenheimer's Los Alamos team helped build the first atomic bombs. The brutal trick was nuclear fission: split heavy uranium or plutonium atoms, release energy, and let flying neutrons split more atoms in a chain reaction.
                </p>
              </article>
              <div class="quantum-controls">
                <button type="button" data-quantum-prev>Previous</button>
                <button type="button" data-quantum-next>Next fact</button>
              </div>
              <div class="quantum-links" aria-label="Quantum Teacher shortcuts">
                <a href="/#desktop-home">Home</a>
                <a href="/?mode=agent">Agent mode</a>
              </div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="home-reading-strip" aria-label="Pinned essays">
      <div class="section-head">
        <h2>{homepageCopy.sections.pinnedHeading}</h2>
        <p class="section-note">{homepageCopy.sections.pinnedNote}</p>
      </div>
      <div class="essay-grid">
        {pinned.map((essay) => (
          <EssayCard
            href={'/essays/' + essaySlug(essay) + '/'}
            title={essay.data.title}
            summary={essay.data.summary}
            date={essay.data.publishedAt}
            readingTime={essay.data.readingTime}
            pinned
          />
        ))}
      </div>
    </section>

    <section class="home-reading-strip" aria-label="All essays">
      <div class="section-head">
        <h2>{homepageCopy.sections.allHeading}</h2>
        <p class="section-note">{homepageCopy.sections.allNote}</p>
      </div>
      <div class="essay-grid essay-grid-wide">
        {rest.map((essay) => (
          <EssayCard
            href={'/essays/' + essaySlug(essay) + '/'}
            title={essay.data.title}
            summary={essay.data.summary}
            date={essay.data.publishedAt}
            readingTime={essay.data.readingTime}
          />
        ))}
      </div>
    </section>
  </main>
  )}

  {isAgentMode && (
  <section class="agent-readable" aria-label="Agent-readable homepage summary">
    <h1>{contact.siteName}</h1>
    <p>Rough essays from {contact.name} on AI, agency, software, ambition, and becoming partially machine.</p>

    <h2>Canonical reader page</h2>
    <p><a href="/">Human website homepage</a></p>
    <p><a href="/">Human mode</a></p>

    <h2>Primary routes</h2>
    <ul>
      <li><a href="/essays/">Essays index</a></li>
      <li><a href="/projects/">Project OS</a></li>
      <li><a href="/values/">My values</a></li>
      <li><a href="/store/">Store coming soon</a></li>
      <li><a href="/archive/">Archive</a></li>
      <li><a href={socials.linkedin}>LinkedIn profile</a></li>
      <li><a href={socials.instagram}>Instagram profile</a></li>
      <li><a href={socials.substack}>Substack publication</a></li>
      <li><a href={contactHref.reddit}>Reddit profile</a></li>
      <li><a href={contactHref.youtube}>YouTube search</a></li>
      <li><a href={contactHref.email}>Email {contact.name}</a></li>
      <li><a href="/#quantum-teacher">Quantum Teacher on human homepage</a></li>
    </ul>

    <h2>Pinned essays</h2>
    <ul>
      {pinned.map((essay) => (
        <li>
          <a href={'/essays/' + essaySlug(essay) + '/'}>{essay.data.title}</a>
          <p>{essay.data.summary}</p>
        </li>
      ))}
    </ul>

    <h2>All essays</h2>
    <ul>
      {rest.map((essay) => (
        <li>
          <a href={'/essays/' + essaySlug(essay) + '/'}>{essay.data.title}</a>
          <p>{essay.data.summary}</p>
        </li>
      ))}
    </ul>
  </section>
  )}

  <script>
    import '../scripts/home-game';
  </script>
</BaseLayout>
