---
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/EssayCard.astro';
import { getPublishedEssays, splitPinned } from '../lib/essays';
import { socials } from '../lib/socials';

const essays = await getPublishedEssays();
const { pinned, rest } = splitPinned(essays);
const latest = rest.slice(0, 6);

const navItems = ['Product OS', 'Pricing', 'Docs', 'Community', 'Company', 'More'];

const leftIcons = [
  { label: 'home.mdx', href: '/', icon: 'doc', mark: 'Aa' },
  { label: 'Product OS', href: '/essays/', icon: 'book', mark: 'P' },
  { label: 'Pricing', href: '/essays/', icon: 'calculator', mark: '$' },
  { label: 'customers.mdx', href: '/essays/', icon: 'sheet', mark: '▦' },
  { label: 'demo.mov', href: '/essays/', icon: 'video', mark: 'DEMO' },
  { label: 'Docs', href: '/essays/', icon: 'book', mark: 'D' },
  { label: 'Talk to a human', href: socials.linkedin, external: true, icon: 'mail', mark: 'in' },
  { label: 'Ask a question', href: socials.instagram, external: true, icon: 'chat', mark: '◎' },
  { label: 'Sign up ↗', href: socials.substack, external: true, icon: 'compass', mark: 'S' },
  { label: 'Switch to website mode', action: 'agent-mode', icon: 'switch', mark: 'T' }
];

const rightIcons = [
  { label: 'Why PostHog?', href: '/essays/', icon: 'bookshelf', mark: 'W' },
  { label: 'Changelog', href: '/essays/', icon: 'calendar', mark: '!' },
  { label: 'Company handbook', href: '/essays/', icon: 'openbook', mark: 'H' },
  { label: 'Store', href: socials.substack, external: true, icon: 'bag', mark: 'S' },
  { label: 'Work here', href: socials.linkedin, external: true, icon: 'typewriter', mark: '⌁' },
  { label: 'Trash', href: '/essays/', icon: 'trash', mark: '↻' }
];
---

<BaseLayout bodyClass="home-desktop-page">
  <main class="posthog-home">
    <section class="retro-desktop" aria-label="Philosophies of a Cyborg reader desktop">
      <header class="posthog-nav" aria-label="Homepage navigation">
        <a class="posthog-logo" href="/" aria-label="Philosophies of a Cyborg home">
          <span aria-hidden="true"></span>
        </a>
        <nav aria-label="Desktop navigation">
          {navItems.map((item) => <a href="/essays/">{item}</a>)}
        </nav>
        <div class="nav-tools" aria-label="Homepage tools">
          <a class="nav-cta" href="/essays/">Get started - free</a>
          <button type="button" aria-label="Search">
            <span class="tool-search" aria-hidden="true"></span>
          </button>
          <button type="button" aria-label="Help">
            <span class="tool-help" aria-hidden="true">?</span>
          </button>
          <span class="tool-count" aria-label="Cart count">0</span>
          <button type="button" aria-label="Profile">
            <span class="tool-profile" aria-hidden="true"></span>
          </button>
        </div>
      </header>

      <div class="desktop-canvas">
        <div class="icon-rail icon-rail-left" aria-label="Primary desktop shortcuts">
          {leftIcons.map((item) => (
            item.action ? (
              <button class="desktop-object" type="button" data-action={item.action}>
                <span class:list={['desktop-glyph', `icon-${item.icon}`]} aria-hidden="true">
                  <span>{item.mark}</span>
                </span>
                <span class="desktop-label">{item.label}</span>
              </button>
            ) : (
              <a
                class="desktop-object"
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noreferrer' : undefined}
              >
                <span class:list={['desktop-glyph', `icon-${item.icon}`]} aria-hidden="true">
                  <span>{item.mark}</span>
                </span>
                <span class="desktop-label">{item.label}</span>
              </a>
            )
          ))}
        </div>

        <div class="garden-scene" aria-hidden="true">
          <div class="garden-plot plot-back">
            <span class="hedge-letter">P</span>
            <i class="flower-row flowers-blue"></i>
            <i class="flower-row flowers-red"></i>
            <i class="flower-row flowers-yellow"></i>
          </div>
          <div class="garden-plot plot-left">
            <span class="hedge-letter">C</span>
            <i class="sprouts sprouts-a"></i>
            <i class="sprouts sprouts-b"></i>
          </div>
          <div class="soil-plot plot-center">
            <i></i><i></i><i></i><i></i><i></i><i></i>
          </div>
          <div class="wood-bed">
            <span></span><span></span><span></span><span></span>
          </div>
          <div class="water-plot">
            <span class="water-letter">G</span>
            <i></i><i></i><i></i>
          </div>
          <div class="garden-plot plot-front">
            <span class="hedge-letter">7</span>
            <i class="sprouts sprouts-c"></i>
          </div>
          <div class="reader-figure">
            <span></span>
          </div>
          <div class="garden-shadow"></div>
        </div>

        <div class="icon-rail icon-rail-right" aria-label="Secondary desktop shortcuts">
          {rightIcons.map((item) => (
            <a
              class="desktop-object"
              href={item.href}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noreferrer' : undefined}
            >
              <span class:list={['desktop-glyph', `icon-${item.icon}`]} aria-hidden="true">
                <span>{item.mark}</span>
              </span>
              <span class="desktop-label">{item.label}</span>
            </a>
          ))}
        </div>

        <aside class="desktop-dock" aria-label="Desktop drawer">
          <button type="button" data-action="close-dock" aria-label="Close desktop drawer">
            <span aria-hidden="true"></span>
          </button>
        </aside>
      </div>
    </section>

    <section class="home-reading-strip" aria-label="Pinned essays">
      <div class="section-head">
        <h2>Pinned</h2>
        <p class="section-note">The desktop is the front door. The writing starts here.</p>
      </div>
      <div class="essay-grid">
        {pinned.map((essay) => (
          <EssayCard
            href={'/essays/' + essay.slug + '/'}
            title={essay.data.title}
            summary={essay.data.summary}
            date={essay.data.publishedAt}
            readingTime={essay.data.readingTime}
            pinned
          />
        ))}
      </div>
    </section>

    <section class="home-reading-strip" aria-label="Latest essays">
      <div class="section-head">
        <h2>Latest</h2>
        <p class="section-note">No admin dashboard here. Just the reader-facing shelf.</p>
      </div>
      <div class="essay-list">
        {latest.map((essay) => (
          <a class="essay-row" href={'/essays/' + essay.slug + '/'}>
            <time datetime={essay.data.publishedAt.toISOString()}>
              {essay.data.publishedAt.toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
            <span>
              <h3>{essay.data.title}</h3>
              <p>{essay.data.summary}</p>
            </span>
            <span class="read-time">{essay.data.readingTime}</span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <section class="agent-readable" aria-label="Agent-readable homepage summary">
    <h1>Philosophies of a Cyborg</h1>
    <p>Essays from Logarn on AI, agency, software, ambition, and becoming partially machine.</p>

    <h2>Canonical reader page</h2>
    <p><a href="/">Human website homepage</a></p>

    <h2>Primary routes</h2>
    <ul>
      <li><a href="/essays/">Essays index</a></li>
      <li><a href={socials.linkedin}>LinkedIn profile</a></li>
      <li><a href={socials.instagram}>Instagram profile</a></li>
      <li><a href={socials.substack}>Substack publication</a></li>
    </ul>

    <h2>Pinned essays</h2>
    <ul>
      {pinned.map((essay) => (
        <li>
          <a href={'/essays/' + essay.slug + '/'}>{essay.data.title}</a>
          <p>{essay.data.summary}</p>
        </li>
      ))}
    </ul>

    <h2>Latest essays</h2>
    <ul>
      {latest.map((essay) => (
        <li>
          <a href={'/essays/' + essay.slug + '/'}>{essay.data.title}</a>
          <p>{essay.data.summary}</p>
        </li>
      ))}
    </ul>
  </section>

  <script>
    import '../scripts/home-game';
  </script>
</BaseLayout>
