---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contact } from '../../lib/contact';
import { homepageCopy } from '../../lib/siteCopy';

const essays = await getCollection('essays');
const sortedEssays = essays.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const primaryEssay = sortedEssays[0];

const formatDate = (date: Date) => date.toISOString().slice(0, 10);

const adminSeed = {
  storageKey: 'poc-admin-cms-editor-v1',
  homepage: homepageCopy,
  articles: sortedEssays.map((essay) => ({
    slug: essay.slug,
    title: essay.data.title,
    summary: essay.data.summary,
    publishedAt: formatDate(essay.data.publishedAt),
    updatedAt: essay.data.updatedAt ? formatDate(essay.data.updatedAt) : '',
    status: essay.data.status,
    pinned: essay.data.pinned,
    readingTime: essay.data.readingTime,
    mood: essay.data.mood ?? '',
    body: essay.body
  })),
  draft: primaryEssay
    ? {
        slug: primaryEssay.slug,
        title: primaryEssay.data.title,
        summary: primaryEssay.data.summary,
        publishedAt: formatDate(primaryEssay.data.publishedAt),
        updatedAt: primaryEssay.data.updatedAt ? formatDate(primaryEssay.data.updatedAt) : '',
        status: primaryEssay.data.status,
        pinned: primaryEssay.data.pinned,
        readingTime: primaryEssay.data.readingTime,
        mood: primaryEssay.data.mood ?? '',
        body: primaryEssay.body
      }
    : {
        slug: 'new-essay',
        title: 'New Cyborg Essay',
        summary: 'A tight summary for the home page and essay index.',
        publishedAt: formatDate(new Date()),
        updatedAt: '',
        status: 'draft',
        pinned: false,
        readingTime: '5 min',
        mood: 'sharp',
        body: 'Start with the line that will make the reader keep going.\\n\\n## Then prove it\\n\\nA useful paragraph belongs here.'
      }
};

const seedJson = JSON.stringify(adminSeed).replace(/</g, '\\u003c');
---

<BaseLayout title={`Admin CMS | ${contact.siteName}`}>
  <main class="admin-cms" data-admin-app>
    <header class="admin-hero">
      <div>
        <p class="admin-kicker">Writing studio</p>
        <h1>Write. Preview. Ship.</h1>
        <p class="admin-intro">
          A tiny local CMS: draft in the browser, preview the reader output, then export the exact files the repo needs.
        </p>
      </div>
      <div class="admin-console">
        <div class="admin-actions" aria-label="Studio commands">
          <button class="solid-command" type="button" id="focus-mode">Focus editor</button>
          <a class="text-command command-link" href="/" target="_blank" rel="noreferrer">View site</a>
        </div>
        <div class="admin-meter" aria-label="Current draft state">
          <span>
            <strong id="metric-status">Draft</strong>
            Status
          </span>
          <span>
            <strong id="metric-pin">No</strong>
            Pinned
          </span>
          <span>
            <strong id="metric-path">new-essay.md</strong>
            Export
          </span>
        </div>
      </div>
    </header>

    <section class="admin-grid" aria-label="Admin editor workspace">
      <aside class="admin-panel inventory-panel" aria-label="CMS inventory">
        <div class="panel-head">
          <div>
            <p class="panel-label">Dashboard</p>
            <h2>Inventory</h2>
          </div>
          <button class="text-command" type="button" id="reset-draft">Reset draft</button>
        </div>

        <section class="home-controls" aria-label="Homepage copy controls">
          <div class="section-title">
            <h3>Homepage copy</h3>
            <small>Exports to src/lib/siteCopy.ts</small>
          </div>
          <label>
            Eyebrow
            <input id="home-eyebrow" type="text" autocomplete="off" />
          </label>
          <label>
            Headline
            <input id="home-headline" type="text" autocomplete="off" />
          </label>
          <label>
            Intro
            <textarea id="home-intro" rows="4"></textarea>
          </label>
          <label>
            CTA label
            <input id="home-cta" type="text" autocomplete="off" />
          </label>
        </section>

        <section aria-label="Existing articles">
          <div class="subhead">
            <h3>Articles</h3>
            <button class="text-command" type="button" id="new-draft">New</button>
          </div>
          <div class="article-list" id="article-list"></div>
        </section>
      </aside>

      <section class="admin-panel editor-panel" aria-label="Article editor">
        <div class="panel-head">
          <div>
            <p class="panel-label">Editor</p>
            <h2>Article draft</h2>
          </div>
          <span class="save-state" id="save-state" aria-live="polite">Local draft ready</span>
        </div>

        <div class="readiness-bar" id="readiness-bar" aria-live="polite">
          <strong id="ready-state">Checking draft</strong>
          <span id="ready-detail">Title, slug, date, and export path will be validated here.</span>
        </div>

        <div class="metadata-grid">
          <label class="wide-field">
            Title
            <input id="field-title" type="text" autocomplete="off" />
          </label>
          <label>
            Slug
            <input id="field-slug" type="text" autocomplete="off" />
          </label>
          <label class="wide-field">
            Summary
            <textarea id="field-summary" rows="3"></textarea>
          </label>
          <label>
            Reading time
            <input id="field-reading-time" type="text" autocomplete="off" />
          </label>
          <label>
            Mood
            <input id="field-mood" type="text" autocomplete="off" />
          </label>
          <label>
            Published date
            <input id="field-published-at" type="date" />
          </label>
          <label>
            Updated date
            <input id="field-updated-at" type="date" />
          </label>
          <label>
            Status
            <select id="field-status">
              <option value="draft">Draft</option>
              <option value="published">Published</option>
            </select>
          </label>
          <div class="switch-stack" aria-label="Publish and pin controls">
            <label class="toggle-row">
              <input id="field-pinned" type="checkbox" />
              <span>Pin on home</span>
            </label>
            <label class="toggle-row">
              <input id="quick-publish" type="checkbox" />
              <span>Ready to publish</span>
            </label>
          </div>
        </div>

        <div class="toolbar" role="toolbar" aria-label="Markdown formatting controls">
          <button type="button" data-format="h1" title="Heading 1">H1</button>
          <button type="button" data-format="h2" title="Heading 2">H2</button>
          <button type="button" data-format="h3" title="Heading 3">H3</button>
          <button type="button" data-format="link" title="Insert link">Link</button>
          <button type="button" data-format="underline" title="Underline">U</button>
          <button type="button" data-format="color" data-color="#f14a36" title="Red text">
            <span class="swatch red"></span>
          </button>
          <button type="button" data-format="color" data-color="#119c68" title="Green text">
            <span class="swatch green"></span>
          </button>
          <button type="button" data-format="color" data-color="#245bd4" title="Blue text">
            <span class="swatch blue"></span>
          </button>
        </div>

        <label class="body-label" for="field-body">Markdown body</label>
        <textarea id="field-body" class="body-editor" spellcheck="true"></textarea>
      </section>

      <aside class="preview-column" aria-label="Preview and export">
        <section class="admin-panel preview-panel">
          <div class="panel-head compact">
            <div>
              <p class="panel-label">Preview</p>
              <h2>Reader output</h2>
            </div>
            <span class="status-pill" id="preview-status">draft</span>
          </div>
          <article class="preview-article">
            <p class="preview-meta" id="preview-meta"></p>
            <h1 id="preview-title"></h1>
            <p class="preview-summary" id="preview-summary"></p>
            <div class="preview-body" id="preview-body"></div>
          </article>
        </section>

        <section class="admin-panel export-panel" aria-label="Markdown export">
          <div class="panel-head compact">
            <div>
              <p class="panel-label">Export</p>
              <h2>Frontmatter</h2>
            </div>
          </div>
          <label class="path-label" for="export-output">
            Target path
            <output id="export-path">src/content/essays/new-essay.md</output>
          </label>
          <textarea id="export-output" readonly spellcheck="false"></textarea>
          <label class="path-label home-export-label" for="home-export-output">
            Homepage copy target
            <output id="home-export-path">src/lib/siteCopy.ts</output>
          </label>
          <textarea id="home-export-output" readonly spellcheck="false"></textarea>
          <div class="export-actions">
            <button class="solid-command" type="button" id="copy-markdown">Copy article</button>
            <button class="text-command" type="button" id="copy-homepage">Copy homepage</button>
            <button class="text-command" type="button" id="download-markdown">Export .md</button>
          </div>
          <p class="copy-feedback" id="copy-feedback" aria-live="polite">
            Browser storage only. Copy or export this file for a real repository commit.
          </p>
        </section>
      </aside>
    </section>
  </main>

  <script is:inline id="admin-seed" type="application/json" set:html={seedJson}></script>
  <script is:inline>
    const seedEl = document.getElementById('admin-seed');
    const seed = JSON.parse(seedEl.textContent);
    const storageKey = seed.storageKey;

    const els = {
      articleList: document.getElementById('article-list'),
      app: document.querySelector('[data-admin-app]'),
      focusMode: document.getElementById('focus-mode'),
      resetDraft: document.getElementById('reset-draft'),
      newDraft: document.getElementById('new-draft'),
      saveState: document.getElementById('save-state'),
      readyState: document.getElementById('ready-state'),
      readyDetail: document.getElementById('ready-detail'),
      readinessBar: document.getElementById('readiness-bar'),
      metricStatus: document.getElementById('metric-status'),
      metricPin: document.getElementById('metric-pin'),
      metricPath: document.getElementById('metric-path'),
      homeEyebrow: document.getElementById('home-eyebrow'),
      homeHeadline: document.getElementById('home-headline'),
      homeIntro: document.getElementById('home-intro'),
      homeCta: document.getElementById('home-cta'),
      title: document.getElementById('field-title'),
      slug: document.getElementById('field-slug'),
      summary: document.getElementById('field-summary'),
      readingTime: document.getElementById('field-reading-time'),
      mood: document.getElementById('field-mood'),
      publishedAt: document.getElementById('field-published-at'),
      updatedAt: document.getElementById('field-updated-at'),
      status: document.getElementById('field-status'),
      pinned: document.getElementById('field-pinned'),
      quickPublish: document.getElementById('quick-publish'),
      body: document.getElementById('field-body'),
      previewStatus: document.getElementById('preview-status'),
      previewMeta: document.getElementById('preview-meta'),
      previewTitle: document.getElementById('preview-title'),
      previewSummary: document.getElementById('preview-summary'),
      previewBody: document.getElementById('preview-body'),
      exportPath: document.getElementById('export-path'),
      exportOutput: document.getElementById('export-output'),
      homeExportPath: document.getElementById('home-export-path'),
      homeExportOutput: document.getElementById('home-export-output'),
      copyMarkdown: document.getElementById('copy-markdown'),
      copyHomepage: document.getElementById('copy-homepage'),
      downloadMarkdown: document.getElementById('download-markdown'),
      copyFeedback: document.getElementById('copy-feedback')
    };

    const today = new Date().toISOString().slice(0, 10);
    const blankDraft = {
      slug: 'untitled-cyborg-note',
      title: 'Untitled Cyborg Note',
      summary: 'A sharp one-line promise for the reader.',
      publishedAt: today,
      updatedAt: '',
      status: 'draft',
      pinned: false,
      readingTime: '4 min',
      mood: 'sharp',
      body: '# Working title\n\nOpen with the uncomfortable truth.\n\n## Make it useful\n\nThen turn the premise into something a reader can use.'
    };

    let appState = loadState();

    function loadState() {
      try {
        const saved = JSON.parse(localStorage.getItem(storageKey));
        if (saved && saved.draft) {
          return {
            homepage: { ...seed.homepage, ...saved.homepage },
            draft: { ...seed.draft, ...saved.draft }
          };
        }
      } catch {
        localStorage.removeItem(storageKey);
      }

      return {
        homepage: { ...seed.homepage },
        draft: { ...seed.draft }
      };
    }

    function saveState() {
      localStorage.setItem(storageKey, JSON.stringify(appState));
      els.saveState.textContent = 'Saved to localStorage';
      window.clearTimeout(saveState.timer);
      saveState.timer = window.setTimeout(() => {
        els.saveState.textContent = 'Local draft ready';
      }, 1600);
    }

    function writeFields() {
      els.homeEyebrow.value = appState.homepage.eyebrow;
      els.homeHeadline.value = appState.homepage.headline;
      els.homeIntro.value = appState.homepage.intro;
      els.homeCta.value = appState.homepage.cta;
      els.title.value = appState.draft.title;
      els.slug.value = appState.draft.slug;
      els.summary.value = appState.draft.summary;
      els.readingTime.value = appState.draft.readingTime;
      els.mood.value = appState.draft.mood;
      els.publishedAt.value = appState.draft.publishedAt;
      els.updatedAt.value = appState.draft.updatedAt;
      els.status.value = appState.draft.status;
      els.pinned.checked = appState.draft.pinned;
      els.quickPublish.checked = appState.draft.status === 'published';
      els.body.value = appState.draft.body;
    }

    function readFields() {
      appState = {
        homepage: {
          eyebrow: els.homeEyebrow.value.trim(),
          headline: els.homeHeadline.value.trim(),
          intro: els.homeIntro.value.trim(),
          cta: els.homeCta.value.trim()
        },
        draft: {
          title: els.title.value.trim(),
          slug: slugify(els.slug.value),
          summary: els.summary.value.trim(),
          readingTime: els.readingTime.value.trim(),
          mood: els.mood.value.trim(),
          publishedAt: els.publishedAt.value || today,
          updatedAt: els.updatedAt.value,
          status: els.status.value,
          pinned: els.pinned.checked,
          body: els.body.value
        }
      };
    }

    function slugify(value) {
      return (value || 'untitled')
        .toLowerCase()
        .trim()
        .replace(/['"]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '')
        .slice(0, 72) || 'untitled';
    }

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function inlineMarkdown(value) {
      return escapeHtml(value)
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\*([^*]+)\*/g, '<em>$1</em>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+|mailto:[^\s)]+|#[^\s)]+|\/[^\s)]+)\)/g, '<a href="$2">$1</a>')
        .replace(/&lt;u&gt;([\s\S]*?)&lt;\/u&gt;/g, '<u>$1</u>')
        .replace(
          /&lt;span style=&quot;color: (#[0-9a-fA-F]{6})&quot;&gt;([\s\S]*?)&lt;\/span&gt;/g,
          '<span style="color: $1">$2</span>'
        );
    }

    function markdownToHtml(markdown) {
      const blocks = [];
      let paragraph = [];
      const flushParagraph = () => {
        if (paragraph.length) {
          blocks.push(`<p>${inlineMarkdown(paragraph.join(' '))}</p>`);
          paragraph = [];
        }
      };

      markdown.split('\n').forEach((line) => {
        const trimmed = line.trim();
        if (!trimmed) {
          flushParagraph();
          return;
        }
        if (trimmed.startsWith('### ')) {
          flushParagraph();
          blocks.push(`<h3>${inlineMarkdown(trimmed.slice(4))}</h3>`);
          return;
        }
        if (trimmed.startsWith('## ')) {
          flushParagraph();
          blocks.push(`<h2>${inlineMarkdown(trimmed.slice(3))}</h2>`);
          return;
        }
        if (trimmed.startsWith('# ')) {
          flushParagraph();
          blocks.push(`<h1>${inlineMarkdown(trimmed.slice(2))}</h1>`);
          return;
        }
        paragraph.push(trimmed);
      });

      flushParagraph();
      return blocks.join('');
    }

    function yamlString(value) {
      return `"${String(value).replace(/\\\\/g, '\\\\\\\\').replace(/"/g, '\\"')}"`;
    }

    function buildMarkdown() {
      const lines = [
        '---',
        `title: ${yamlString(appState.draft.title)}`,
        `summary: ${yamlString(appState.draft.summary)}`,
        `publishedAt: ${appState.draft.publishedAt}`,
        `status: ${appState.draft.status}`,
        `pinned: ${appState.draft.pinned}`,
        `readingTime: ${yamlString(appState.draft.readingTime)}`
      ];

      if (appState.draft.updatedAt) {
        lines.push(`updatedAt: ${appState.draft.updatedAt}`);
      }
      if (appState.draft.mood) {
        lines.push(`mood: ${yamlString(appState.draft.mood)}`);
      }

      lines.push('---', '', appState.draft.body.trim(), '');
      return lines.join('\n');
    }

    function buildHomepageModule() {
      return `export const homepageCopy = ${JSON.stringify(appState.homepage, null, 2)} as const;\n`;
    }

    function validateDraft(slug) {
      const issues = [];
      if (!appState.draft.title.trim()) issues.push('title');
      if (!slug) issues.push('slug');
      if (!appState.draft.publishedAt) issues.push('published date');

      const duplicate = seed.articles.some((article) => {
        return article.slug === slug && article.title !== appState.draft.title;
      });
      if (duplicate) issues.push('duplicate slug');

      if (issues.length) {
        els.readinessBar.dataset.state = 'needs-work';
        els.readyState.textContent = 'Needs work';
        els.readyDetail.textContent = `Fix ${issues.join(', ')} before exporting.`;
        return false;
      }

      els.readinessBar.dataset.state = 'ready';
      els.readyState.textContent = 'Ready to export';
      els.readyDetail.textContent = `${slug}.md and src/lib/siteCopy.ts are generated below.`;
      return true;
    }

    function renderArticleList() {
      els.articleList.innerHTML = '';
      seed.articles.forEach((article) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'article-row';
        button.dataset.slug = article.slug;
        button.innerHTML = `
          <span>
            <strong>${escapeHtml(article.title)}</strong>
            <small>${escapeHtml(article.status)} · ${escapeHtml(article.readingTime)}</small>
          </span>
          <em>${article.pinned ? 'Pinned' : 'Draftable'}</em>
        `;
        button.addEventListener('click', () => {
          appState.draft = { ...article };
          writeFields();
          persistAndRender();
        });
        els.articleList.append(button);
      });
    }

    function render() {
      const slug = appState.draft.slug || slugify(appState.draft.title);
      const exportPath = `src/content/essays/${slug}.md`;
      const homeExportPath = 'src/lib/siteCopy.ts';
      const markdown = buildMarkdown();
      const homepageModule = buildHomepageModule();
      const pinText = appState.draft.pinned ? 'Yes' : 'No';
      const metaParts = [
        appState.draft.publishedAt,
        appState.draft.readingTime,
        appState.draft.mood,
        appState.draft.pinned ? 'pinned' : ''
      ].filter(Boolean);

      els.slug.value = slug;
      appState.draft.slug = slug;
      els.metricStatus.textContent = appState.draft.status;
      els.metricPin.textContent = pinText;
      els.metricPath.textContent = `${slug}.md`;
      els.quickPublish.checked = appState.draft.status === 'published';
      els.previewStatus.textContent = appState.draft.status;
      els.previewTitle.textContent = appState.draft.title || 'Untitled';
      els.previewSummary.textContent = appState.draft.summary;
      els.previewMeta.textContent = metaParts.join(' / ');
      els.previewBody.innerHTML = markdownToHtml(appState.draft.body);
      els.exportPath.textContent = exportPath;
      els.exportOutput.value = markdown;
      els.homeExportPath.textContent = homeExportPath;
      els.homeExportOutput.value = homepageModule;
      validateDraft(slug);
    }

    function persistAndRender() {
      readFields();
      saveState();
      render();
    }

    function applyFormat(format, color) {
      const textarea = els.body;
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const selected = textarea.value.slice(start, end);
      let replacement = selected;

      if (format === 'h1' || format === 'h2' || format === 'h3') {
        const mark = '#'.repeat(Number(format.slice(1)));
        replacement = selected
          ? selected
              .split('\n')
              .map((line) => `${mark} ${line.replace(/^#+\\s*/, '')}`)
              .join('\n')
          : `${mark} Heading`;
      }

      if (format === 'link') {
        const url = window.prompt('Link URL', 'https://');
        if (!url) return;
        replacement = `[${selected || 'link text'}](${url})`;
      }

      if (format === 'underline') {
        replacement = `<u>${selected || 'underlined text'}</u>`;
      }

      if (format === 'color') {
        replacement = `<span style="color: ${color}">${selected || 'colored text'}</span>`;
      }

      textarea.setRangeText(replacement, start, end, 'select');
      textarea.focus();
      persistAndRender();
    }

    document.querySelectorAll('[data-format]').forEach((button) => {
      button.addEventListener('click', () => {
        applyFormat(button.dataset.format, button.dataset.color);
      });
    });

    [
      els.homeEyebrow,
      els.homeHeadline,
      els.homeIntro,
      els.homeCta,
      els.slug,
      els.summary,
      els.readingTime,
      els.mood,
      els.publishedAt,
      els.updatedAt,
      els.status,
      els.pinned,
      els.body
    ].forEach((control) => {
      control.addEventListener('input', persistAndRender);
      control.addEventListener('change', persistAndRender);
    });

    els.quickPublish.addEventListener('change', () => {
      els.status.value = els.quickPublish.checked ? 'published' : 'draft';
      persistAndRender();
    });

    els.title.addEventListener('input', () => {
      if (!els.slug.dataset.touched) {
        els.slug.value = slugify(els.title.value);
      }
      persistAndRender();
    });

    els.slug.addEventListener('input', () => {
      els.slug.dataset.touched = 'true';
    });

    els.resetDraft.addEventListener('click', () => {
      localStorage.removeItem(storageKey);
      appState = {
        homepage: { ...seed.homepage },
        draft: { ...seed.draft }
      };
      els.slug.dataset.touched = '';
      writeFields();
      persistAndRender();
    });

    els.newDraft.addEventListener('click', () => {
      appState.draft = { ...blankDraft };
      els.slug.dataset.touched = '';
      writeFields();
      persistAndRender();
    });

    els.copyMarkdown.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(els.exportOutput.value);
        els.copyFeedback.textContent = 'Article markdown copied.';
      } catch {
        els.exportOutput.focus();
        els.exportOutput.select();
        els.copyFeedback.textContent = 'Clipboard blocked. Export text selected for manual copy.';
      }
    });

    els.copyHomepage.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(els.homeExportOutput.value);
        els.copyFeedback.textContent = 'Homepage copy module copied.';
      } catch {
        els.homeExportOutput.focus();
        els.homeExportOutput.select();
        els.copyFeedback.textContent = 'Clipboard blocked. Homepage export selected for manual copy.';
      }
    });

    els.downloadMarkdown.addEventListener('click', () => {
      const blob = new Blob([els.exportOutput.value], { type: 'text/markdown' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `${appState.draft.slug || 'essay'}.md`;
      link.click();
      URL.revokeObjectURL(url);
      els.copyFeedback.textContent = 'Markdown file exported from the browser.';
    });

    els.focusMode.addEventListener('click', () => {
      const enabled = !els.app.classList.contains('focus-mode');
      els.app.classList.toggle('focus-mode', enabled);
      els.focusMode.textContent = enabled ? 'Show panels' : 'Focus editor';
    });

    renderArticleList();
    writeFields();
    render();
  </script>

