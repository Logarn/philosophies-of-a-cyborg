---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin | Philosophies of a Cyborg">
  <main class="page">
    <section class="section">
      <div class="section-head">
        <h2>Admin</h2>
        <p class="section-note">Three actions. That is the whole machine. Anything more goes in the furnace until it earns rent.</p>
      </div>

      <div class="admin-actions">
        <button class="admin-action" type="button">
          <strong>Publish</strong>
          <p>Take a draft live after the required metadata passes. This is the big red button, except less lawsuit-shaped.</p>
        </button>
        <button class="admin-action" type="button">
          <strong>Pin</strong>
          <p>Promote the best essays to the top of the home page and essays page. Taste beats chronology.</p>
        </button>
        <button class="admin-action" type="button">
          <strong>Edit Draft</strong>
          <p>Open the current working draft. No menus, no maze, no aircraft panel pretending to be productivity.</p>
        </button>
      </div>
    </section>
  </main>
</BaseLayout>
