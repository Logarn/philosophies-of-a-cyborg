# Admin auth is enforced server-side for /admin.
# Generate a password hash with:
#   node -e "const crypto=require('node:crypto'); console.log(crypto.createHash('sha256').update(process.argv[1]).digest('hex'))" 'your-long-password'
ADMIN_USERNAME=ositu
ADMIN_PASSWORD_SHA256=replace_with_sha256_hash

# On Vercel, set this to a GitHub fine-grained token with Contents: Read and Write
# for Logarn/philosophies-of-a-cyborg. Admin publish/delete commits directly to
# this branch, and Vercel's Git integration deploys the commit.
POC_GITHUB_TOKEN=github_pat_replace_me
POC_GITHUB_REPO=Logarn/philosophies-of-a-cyborg
POC_GITHUB_BRANCH=main
